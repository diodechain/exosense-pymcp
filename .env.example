# ExoSense MCP server – copy to .env and fill in values.
# .env is gitignored; use it for local/deployment-specific config.
# Diode Deploy: do NOT bundle .env into the tarball (see scripts/diode_deploy_bundle.sh). Copy every
# setting you need into the Diode Deploy project’s container/environment configuration so production matches.

# EXOSENSE_API_URL=https://api.exosense.com
# EXOSENSE_ORIGIN=https://exosense.com
# EXOSENSE_AUTH_TOKEN=your-token-here
# LOG_LEVEL=INFO
# HTTP_STREAMING=Private

# Diode: default is embedded (omit this). Set only for sidecar publish:
# DIODE_CLIENT=container
# PORT=9000 # our localhost port the server publishes on

# Bind address for HTTP MCP (default 127.0.0.1).
# LISTEN_HOST=127.0.0.1

# Diode: for private networks, set your join address here (omit for public publish).
# Kept in .env so it doesn’t conflict when deploying to different environments.
# DIODE_JOIN_ADDRESS=0x...

# Diode deploy MCP (Cursor): .cursor/mcp.json references these via ${env:...}. Set them here and
# ensure Cursor sees them in its environment (e.g. launch Cursor from a shell after `set -a && source .env && set +a`, or direnv). See README “Diode deploy MCP”.
# DIODE_MCP_DEPLOY_TARGET=diode://0x....diode:30000
# DIODE_MCP_DEPLOY_UUID=
